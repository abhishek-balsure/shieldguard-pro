# EC2 Deployment - Use this with Docker Compose
SECRET_KEY=your-production-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# Docker Compose services (db and redis are service names in docker-compose.yml)
DATABASE_URL=postgresql://shieldguard:shieldguard123@db:5432/shieldguarddb
REDIS_URL=redis://redis:6379/0

# PostgreSQL settings (match these with docker-compose.yml)
POSTGRES_DB=shieldguarddb
POSTGRES_USER=shieldguard
POSTGRES_PASSWORD=shieldguard123

FLASK_ENV=production
